{
    "name": "shopwalk-inc/woocommerce-ucp",
    "description": "WooCommerce UCP — Universal Commerce Protocol",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "woocommerce/qit-cli": "^0.7",
        "phpunit/phpunit": "^10",
        "brain/monkey": "^2.6"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "qit:security": "qit run:security woocommerce-ucp",
        "qit:phpcs": "qit run:phpcs woocommerce-ucp",
        "qit:activation": "qit run:activation woocommerce-ucp"
    }
}
