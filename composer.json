{
    "name": "shopwalk-inc/ucp-for-woocommerce",
    "description": "UCP for WooCommerce — Universal Commerce Protocol",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "woocommerce/qit-cli": "^0.7",
        "phpunit/phpunit": "^10",
        "brain/monkey": "^2.6"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "qit:security": "qit run:security ucp-for-woocommerce",
        "qit:phpcs": "qit run:phpcs ucp-for-woocommerce",
        "qit:activation": "qit run:activation ucp-for-woocommerce"
    }
}
